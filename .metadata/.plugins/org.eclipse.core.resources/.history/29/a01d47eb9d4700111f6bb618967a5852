package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

//14.  Given a list of Strings, create a list that contains only integers.  
//input: String [] s = {"abc", "123", "456", "xyz"}; 
//output: [123, 456]
public class Program16 {
	
	public static void main(String[] args) {
		
		String [] s = {"abc", "123", "456", "xyz"}; 
		
		Map<Integer, List<String>> collect = Arrays.stream(s)
		.distinct()
		.collect(Collectors.groupingBy(e ->  e.matches("\\d+") ));
		
		System.out.println(collect);
		 
		 
	   
	 
		
	}

}
