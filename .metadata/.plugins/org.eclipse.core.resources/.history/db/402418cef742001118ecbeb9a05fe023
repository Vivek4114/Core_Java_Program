			List<String> li = Arrays.asList("Hi", "My", "Name", "Vivek");
			li.stream().forEach(System.out::println);
			System.out.println("====================================================");
			li.parallelStream().forEach(System.out::println);
			
			System.out.println("====================================================");
			int arr[] = {29,29,290,8,38,29,59,37,46};
			IntStream stream = Arrays.stream(arr);
			stream.forEach(System.out::println);
			System.out.println("====================================================");
			Long a[] = {29L,29L,290L,8L,38L,29L,59L,37L};
			 = Arrays.stream(a);;
			stream.forEach(System.out::println);
			System.out.println("====================================================");
	}

}
