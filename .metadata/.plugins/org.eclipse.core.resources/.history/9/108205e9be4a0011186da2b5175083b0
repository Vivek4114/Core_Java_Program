/* 

30. Merge two sorted arrays

Input:
{1,3,5}, {2,4,6}
Output:
{1,2,3,4,5,6}
*/

 class Program37{
	 public static void main(String []args) {
		  
		 int arr1[] = {1,3,5};
		 int arr2[] = {2,4,6};
		 
		 Set<Integer> collect = Stream
				 				.of(arr1,arr2)
				 				.flatMapToInt(s -> Arrays.stream(s))
				 				.boxed()
				 				.sorted()
				 				.collect(Collectors.toSet());
		 
		 System.out.println(collect);
		 	 }
 }