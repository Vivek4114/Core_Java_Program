package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

//13.  Given an array of Integers, group the numbers by the range in which they belong.  
//input: int []arr= {2, 3, 10, 14, 20, 24, 30, 34, 40, 44, 50, 54}; 
//output: {0=[2, 3], 10=[10, 14], 20=[20, 24], 30=[30, 34], 40=[40, 44], 50=[50, 54]}
public class Program16 {
	
	public static void main(String[] args) {
		
		int []arr= {2, 3, 7,8,15,67,3,5,7,8,99,33,77,4,3,2,4,4,455,76,33,6, 10, 14, 20, 24, 30, 34, 40, 44, 50, 54}; 
   
		 
		 Map<Integer, List<Integer>> collect = Arrays.stream(arr)
		 .distinct() 
		 .sorted()
		 .boxed()
		 .collect(Collectors.groupingBy(e -> e/10));
		 
		 System.out.println(collect);
		
		 
		 
	   
	 
		
	}

}
