package com.nit.terminalOperation;

import java.util.Arrays;

public class Program03_AnyMatch {
	
	public static void main(String[] args) {
		
		
		String arr[] = {"Kalpana","Pooja","Darshana","Payal","Samiksha","Diksha","Savita"};
		
		
	boolean result = 	Arrays.stream(arr).anyMatch(n -> n.startsWith("D"));
	System.out.println(result);
	
	boolean noneMatch = Arrays.stream(arr).noneMatch(a -> a.startsWith("M"));
		
	if(nonMatch)
		System.out.println("anything is not match");
	else
		System.out.println("Some thing is match");
	}

}
