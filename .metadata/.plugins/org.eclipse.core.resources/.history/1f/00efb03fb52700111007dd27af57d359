package com.nit.deadlockSituation;
public class DeadLockProg{
	
	public static void main(String[] args) {
		 
		final Object lock1=new Object();
		final Object lock2=new Object();
		
		Thread t1=new Thread(()->{
			synchronized(lock1) {
				System.out.println("Thread 1 lock");
				
				try {
					Thread.sleep(200);
				}
				catch(Exception e) {
					
				}
				
				synchronized(lock2) {
					System.out.println("Thread 1 Lock 2");
				}
			}
		});
		
		
		Thread t2=new Thread(()->{
			synchronized(lock2) {
				System.out.println("Thread 2 lock");
				
				try {
					Thread.sleep(200);
				}
				catch(Exception e) {
					
				}			
				synchronized(lock1) {
					System.out.println("Thread 2 Lock 1");
				}
			}
		});
		
		t1.start();
		t2.start();
	}
	
	
	
}

