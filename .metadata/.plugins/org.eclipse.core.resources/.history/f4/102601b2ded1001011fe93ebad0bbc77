package com.nit.Dec5;

import java.util.stream.Stream;

public class AStartName {
	public static void main(String[] args) {
		Stream<String> names = Stream.of("Akash","Boby","Chinu","Anjali","Dev","Anuj", "Akansha");
		
		Stream filteredName = names.filter(str -> str.startsWith("A"));
		filteredName.forEach(System.out::println);
		
	}

}
