package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.Optional;

//Given a sentence, find the word that has the 2nd(nth) highest length. 
//input: String s = "I am learning streams API in Java"; 
//output: streams 

public class Program03 {
	
	public static void main(String[] args) {
		
		String s = "I am learning streams API in Java"; 
		
		Optional<String> max = Arrays
		.stream(s.split(" "))
		.max((e1,e2)-> Integer.compare(e1.length(), e2.length()))
		
		;
		
		max.ifPresent(System.out::println);
		
		
	}

}
