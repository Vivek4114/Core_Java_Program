package com.nit.StreamProg;

import java.util.ArrayList;
import java.util.stream.Collectors;

record Product(Integer id, String name) {};


public class Program07_Collector_ToMap {
	
	public static void main(String[] args) {
		
		Product p  = new Product(11, "Mobile");
		Product p1  = new Product(22, "Laptop");  
		Product p2  = new Product(22, "Watch");  
		
		ArrayList<Product> liprod = new ArrayList<>();
		liprod.add(p);
		liprod.add(p1);
		liprod.add(p2);
		
		liprod.stream().collect(Collectors.toMap(Product::id,Product::name));
		
		
		
	}

}
