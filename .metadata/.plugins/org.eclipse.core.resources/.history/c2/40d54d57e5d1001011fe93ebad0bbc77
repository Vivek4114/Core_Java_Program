package com.nit.Dec5;

import java.util.List;
import java.util.stream.Collectors;
import java.util.stream.Stream;

//Write a program to Create A Stream of Name of your Friends, Filter out the names starting with 'A' and then d
//display the filtered stream


public class AStartName {
	public static void main(String[] args) {
		Stream<String> names = Stream.of("Akash","Boby","Chinu","Anjali","Dev","anuj", "Akansha"); 	
		List<String> list = names.filter(str -> str.startsWith("A")).collect(Collectors.toList());
		list.forEach(System.out::println);
		
	}

}
