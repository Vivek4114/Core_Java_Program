package com.nit.StreamApi;

import java.util.Arrays;
import java.util.List;
import java.util.Queue;
import java.util.Set;
import java.util.stream.Collectors;

//Write a program to create employee object each employee have name, designation sal yoe
// Filter and display the employee whose sal is more than 50000 


//Write a program to create a list of words convert each one of them into uppercase and then display

public class Test02_Employee_obj_Stream {
	public static void main(String[] args) {
		
		List<Employee> emp = Arrays.asList(
				new Employee("Raju","Jr. Developer", 20393, 3),
				new Employee("Dikshit","Test Engineer", 60393, 2),
				new Employee("Chandu","Devops", 70393, 1),
				new Employee("Jagdish"," CEO", 90393, 1),
				new Employee("Abhay","Team Leader", 78393, 5)
				);
				
		
	List<Employee> seniorEmployee = 	emp.stream().
			filter(e -> e.getSal() > 50000).collect(Collectors.toList());
	 System.out.println("Employee With salary more than 50000");
	seniorEmployee.forEach(System.out::println);
	
	Set<Employee> seniorEmployee1 = 	emp.stream().
	filter(e -> e.getSal() > 50000).collect(Collectors.toSet());
	
	Queue<Employee> seniorEmployee2 = 	emp.stream().
			filter(e -> e.getSal() > 50000).collect(Collectors.asQueue());
	
	 
	 System.out.println("Employee With salary more than 50000");
	seniorEmployee.forEach(System.out::println);
	
	
	 
		
	}
}

class Employee{
	String name;
	String designation;
	double sal;
	int yoe;
	
	public Employee(String name, String designation, double sal, int yoe) {
		super();
		this.name = name;
		this.designation = designation;
		this.sal = sal;
		this.yoe = yoe;
	}
	
	public String getName() {
		return name;
	}
	 
	public void setName(String name) {
		this.name = name;
	}
	 
	public String getDesignation() {
		return designation;
	}
	 
	public void setDesignation(String designation) {
		this.designation = designation;
	}
	 
	public double getSal() {
		return sal;
	}
	 
	public void setSal(double sal) {
		this.sal = sal;
	}
	 
	public int getYoe() {
		return yoe;
	}
	 
	public void setYoe(int yoe) {
		this.yoe = yoe;
	}
	@Override
	public String toString() {
		return "Employee [name=" + name + ", designation=" + designation + ", sal=" + sal + ", yoe=" + yoe + "]";
	}
 
}
