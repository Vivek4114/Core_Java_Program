/* 
31. Find all substrings of a string

Input:
"abc"
Output:
[a, b, c, ab, bc, abc]
*/

class Program37 {
	public static void main(String[] args) {
		
		String s = "abc";
		
		Stream<String> flatMap = IntStream.range(0, s.length())
		.boxed()
		.flatMap(i -> IntStream.range(i+1, s.length()+1).mapToObj(j -> s.substring(i,j)));
		System.out.println(flatMap);
		
	 

	}
}