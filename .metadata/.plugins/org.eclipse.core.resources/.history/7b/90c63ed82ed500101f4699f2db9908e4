package com.nit.jdbc;

import java.util.Scanner;

import java.sql.DriverManager;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.ResultSetMetaData;

public class Test_03_TryWithResource {
	public static void main(String[] args) {

		Scanner sc = new Scanner(System.in);
		StringBuilder sb = new StringBuilder("");
		System.out.println("Enter the How many course you want to enter");
		int n = sc.nextInt();
		sc.nextLine();

		for (int i = 1; i <= n; i++) {
			sb.append("?");
			if (i < n) {
				sb.append(",");
			}
		}

		try (Connection conn = DriverManager.getConnection("jdbc:oracle:thin:@localhost:1521:orcl", "c##vivek",
				"vivek");

				PreparedStatement pstmt = conn.prepareStatement("""
						select s.sid, s.sname, c.course_name, c.course_fee
						from student01 s, course01 c
						where s.course_id = c.course_id
						order by c.course_id

						""");
				PreparedStatement pstmt2 = conn.prepareStatement(

						"select s.sid, s.sname, c.course_name, c.course_fee " + "from student01 s, course01 c "
								+ "where s.course_id = c.course_id " + "and course_name IN (" + sb + ")"

				);

		) {

			ResultSet rs = null;
			ResultSetMetaData rsmd = null;
			System.out.println("Enter 1 For All Student");
			System.out.println("Enter 2 For Specific Student");

			int option = sc.nextInt();
			sc.nextLine();

			switch (option) {
			case 1: {
				rs = pstmt.executeQuery();
				
				rsmd = pstmt.getMetaData();
				int count = rsmd.getColumnCount();
				String course_name ;
				int maxGap;
				for(int i = 1; i<= count; i++) {
					 course_name = rsmd.getColumnName(i);
					  maxGap = Math.max(rsmd.getPrecision(i), course_name.length());
					  System.out.printf("%"+maxGap+"s ",course_name);
				}
			
				
				
				while (rs.next()) {
					System.out.println(
							rs.getInt(1) + " " + rs.getString(2) + " " + rs.getString(3) + " " + rs.getString(4));
				}

			}

			case 2: {

				for (int i = 1; i <= n; i++) {
					System.out.println("Enter the Course Name : " + i);
					pstmt2.setString(i, sc.nextLine());

				}
				// System.out.println(sb);
				rs = pstmt2.executeQuery();

				while (rs.next()) {
					System.out.println(
							rs.getInt(1) + " " + rs.getString(2) + " " + rs.getString(3) + " " + rs.getString(4));
				}

			}

			}

		}

		catch (Exception e) {
			e.printStackTrace();
		}
	}

}
