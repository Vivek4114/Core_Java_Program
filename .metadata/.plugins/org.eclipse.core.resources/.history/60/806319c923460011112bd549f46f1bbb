package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.stream.Collector;
import java.util.stream.Collectors;

//8. Given a word, find the occurrence of each character.  
//input:  String s = "Mississippi"; 
//output: {p=2, s=4, i=4, M=1}

public class Program10 {
	
	public static void main(String[] args) {
		
		String s = "Mississippi"; 
		
		Arrays.stream(s.split("")).collect(Collectors.groupingBy(m -> m, Collectors.counting())).forEach((k,v)->System.out.println(k +" = "+ v));;
		
	   
	 
		
	}

}
