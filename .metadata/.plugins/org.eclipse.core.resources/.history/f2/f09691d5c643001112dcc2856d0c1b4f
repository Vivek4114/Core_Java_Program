package com.nit.methodref;

@FunctionalInterface
interface Worker{
	
	public  void work();
	
}

class Employee  {

	public  void work() {
		System.out.println("Worker are working");
	}
	
}


public class Program_01_NSMR {
	
	public static void main(String[] args) {
		
		 Worker w1 = () -> System.out.print("Employee is working");
		 w1.work();
		
		 
	}

}
