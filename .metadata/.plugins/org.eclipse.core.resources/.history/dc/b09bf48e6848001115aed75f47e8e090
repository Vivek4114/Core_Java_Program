public class Program30 {
	
	public static void main(String[] args) {
		int[] arr1 = {1,2,3,4};
		int[] arr2 = {3,4,5,6};
	
		  List<Integer> collect = Arrays.stream(arr1).boxed().collect(Collectors.toList());
