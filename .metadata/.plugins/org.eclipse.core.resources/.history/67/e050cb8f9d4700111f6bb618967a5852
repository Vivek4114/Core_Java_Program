package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

//14.  Given a list of Strings, create a list that contains only integers.  
//input: String [] s = {"abc", "123", "456", "xyz"}; 
//output: [123, 456]
public class Program16 {
	
	public static void main(String[] args) {
		
		int []arr= {2, 3, 7,8,15,67,3,5,7,8,99,33,77,4,3,2,4,4,455,76,33,6, 10, 14, 20, 24, 30, 34, 40, 44, 50, 54}; 
   
		 
		 Map<Integer, List<Integer>> collect = Arrays.stream(arr)
		 .distinct() 
		 .sorted()
		 .boxed()
		 .collect(Collectors.groupingBy(e -> e/10));
		 
		 System.out.println(collect);
		
		 
		 
	   
	 
		
	}

}
