package com.nit.Dec5;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

public class CheckListPalindrome {
	public static void main(String[] args) {
		List<Integer> intList = new ArrayList<>(Arrays.asList(292, 242, 646, 959, 455, 666, 19));
		
		for(int i= 0; i<intList.size(); i++) {
			
			int temp = intList.get(i);
			int rev = 0;
			while(temp!= 0) {
				int n = temp%10;
				rev += n;
				temp = temp/10;
			}
			
			if(rev == intList.get(i)) {
				System.out.print(i +  " ");
				 
			}
			
			
		}
		
		boolean isPalindrom = true;
		for(int i = 0; i<intList.size(); i++) {
			if(intList.get(i)!=intList.get(intList.size()-1-i)) {
				isPalindrom = false;
			}
		}
		
		if(false) {
			System.out.print(intList);
		}
	}

}
