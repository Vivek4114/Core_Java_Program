package com.nit.terminalOperation;

import java.util.List;
import java.util.Map;
import java.util.function.BiConsumer;
import java.util.stream.Collectors;
import java.util.stream.Stream;

public class Program01_CollectMethod {
	
	
public static void main(String[] args) {
	Stream<String> of = Stream.of("Hello","vivek","What","Are","mre","sir","Doiing");
	Map<Integer, List<String>> collect = of.collect(Collectors.groupingBy(String::length));
	System.out.println(collect);
	
	Stream<Integer> of2 = Stream.of(1,2,3,5,6,7,7,8,8,9,9);
	Map<Boolean, List<Integer>> collect2 = of2.collect(Collectors.partitioningBy(n -> n%2==0));
	System.out.println(collect2.get(true));
	System.out.println(collect2.get(false));
	
	of.collect(Collectors.groupingBy( String::length,   Collectors.counting()));
	
}

}
