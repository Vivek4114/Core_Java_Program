package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.Optional;

//Given a sentence, find the word that has the hight length. 
//input: String s = "I am learning streams API in Java"; 
//output: learning

public class Program01 {

	public static void main(String[] args) {

		String s = "I am learning streams API in Java";

		Optional<Integer> max = Arrays.stream(s.split(" ")).map(String::length)
				.max((e1, e2) -> Integer.compare(e1, e2));
		max.ifPresent(System.out::println);
		
		Optional<String> max2 = Arrays
		.stream(s.split(" "))
		.sorted((o1, o2) ->  Integer.max(o1.length(), o2.length())).findFirst().ifPresent(System.out::println);
		 
		
		max2.ifPresent(System.out::println);

	}

}
