/* 

30. Merge two sorted arrays

Input:
{1,3,5}, {2,4,6}
Output:
{1,2,3,4,5,6}
*/

 class Program36{
	 public static void main(String []args) {
		  
		 int arr1[] = {1,3,5};
		 int arr2[] = {2,4,6};
		 
		 List<int[]> asList = Arrays.asList(arr1);
		 List<int[]> asList2 = Arrays.asList(arr2);
		 List<List<int[]>> asList3 = Arrays.asList(asList, asList2);
		 
	  Set<int[]> collect = asList3.stream().flatMap(s -> s.stream()).collect(Collectors.toSet());
	  System.out.println(collect);
		  
		 	 }
 }