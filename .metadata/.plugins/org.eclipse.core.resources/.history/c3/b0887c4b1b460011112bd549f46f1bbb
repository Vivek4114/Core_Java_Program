package com.nit.practice15quetion;

import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;


// Given a sentence, find the words with a specified number of vowels. 
//No. of vowels : 2 
//input: String s = "I am learning streams API in Java";  
//output:  streams 
//API 
//Java


public class Program07 {
	
	public static void main(String[] args) {
		
		String s = "I am learning streams API in Java"; 
 
	  
		List<String> collect = Arrays.stream(s.split(" "))
		.collect( Collectors.toList());
		
		long count = collect.stream().filter( v-> "aeioAEIOUu".indexOf(v) != -1).count() ;
		System.out.println(count);
   
	 
		
		 
	 
		
		
	 
		
	 
		
		
	}

}
