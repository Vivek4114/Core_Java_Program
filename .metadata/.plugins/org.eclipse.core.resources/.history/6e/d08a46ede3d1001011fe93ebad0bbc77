package com.nit.Dec5;

import java.util.List;
import java.util.stream.Collectors;

public class CollectUniqueElement {
	public static void main(String[] args) {
		List<Integer> list = List.of(10,20,30,28,10,20,30,39,20);
		List<Integer> uniqeList = list.stream().distinct().collect(Collectors.toList());
		uniqeList.forEach(System.out::println);
	}

}
