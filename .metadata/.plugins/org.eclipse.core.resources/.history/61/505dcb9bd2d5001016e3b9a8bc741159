package com.nit.StreamApi;

import java.util.Arrays;
import java.util.Comparator;
import java.util.List;
import java.util.Objects;
import java.util.stream.Collectors;


//WAP to create a list of products, each product has name, id, price. 
//there may be chance that products are added into the list with same id.
//filter out the unique products and display them
public class Test05_ListOfProduct {
	public static void main(String[] args) {
		
		List<Product1> ProdList = Arrays.asList(
				new Product1("Electonic", 1, 20000),
				new Product1("Clother", 1, 50000),
				new Product1("Mixer", 2, 10000),
				new Product1("TV", 2, 25000),
				new Product1("Fan", 3, 70000)
				);
		
		 ProdList.stream().
		 sorted(Comparator.comparing(s->s.getProdId())).
		 distinct().
		 collect(Collectors.toList()).
		 forEach(s-> System.out.println(s.getProdId()+" "+s.getProdName()));
				
		
	}

}

